-- Cette insertion sera faite après la création des tables via TypeORM

-- Index pour optimiser les performances
CREATE INDEX idx_bloc_patient_priorite ON bloc_patient(priorite);
CREATE INDEX idx_salle_reveil_statut ON salle_reveil_patient(statut);
CREATE INDEX idx_score_sccre_patient ON score_sccre(patient_reveil_id);
CREATE INDEX idx_sortie_patient_statut ON sortie_patient(statut);
CREATE INDEX idx_patient_destination_sortie ON patient_destination_service(sortie_patient_id);